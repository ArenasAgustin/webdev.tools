{
  "ci": {
    "collect": {
      "numberOfRuns": 2,
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/",
        "http://localhost/playground/json",
        "http://localhost/playground/js"
      ],
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "categories:accessibility": [
          "warn",
          {
            "minScore": 0.95
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "categories:seo": [
          "warn",
          {
            "minScore": 0.95
          }
        ],
        "interactive": [
          "warn",
          {
            "maxNumericValue": 2500
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
